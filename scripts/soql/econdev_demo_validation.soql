-- Cloned Opportunity count by marker
SELECT COUNT() FROM Opportunity WHERE analyticsdemo_batch_id__c LIKE 'ECONDEV_DEMO_OPP_%'

-- Generated Opportunity stage coverage
SELECT StageName, COUNT(Id)
FROM Opportunity
WHERE analyticsdemo_batch_id__c LIKE 'ECONDEV_DEMO_OPP_GEN_%'
GROUP BY StageName
ORDER BY StageName

-- Cloned Site records with demo geography
SELECT Id, Name, Street_Address__c, City__c, State__c, Postal_Zip_Code__c,
       Latitude__c, Longitude__c, Site_Geolocation__Latitude__s, Site_Geolocation__Longitude__s
FROM Site__c
WHERE analyticsdemo_batch_id__c LIKE 'ECONDEV_DEMO_SITE_%'
  AND State__c = 'Texas'

-- Funding Program reference integrity on cloned funding requests
SELECT COUNT() FROM outfunds__Funding_Request__c
WHERE analyticsdemo_batch_id__c LIKE 'ECONDEV_DEMO_FR_%'
  AND outfunds__FundingProgram__c != null

-- Task cloning marker check
SELECT COUNT() FROM Task WHERE analyticsdemo_batch_id__c LIKE 'ECONDEV_DEMO_TASK_%'

-- Generated background checks (underwriting + sampled proposal)
SELECT COUNT() FROM Background_Check__c WHERE analyticsdemo_batch_id__c LIKE 'ECONDEV_DEMO_BG_GEN_%'
